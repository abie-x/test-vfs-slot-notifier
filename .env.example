# Redis — used for per-centre slot state persistence across restarts
# Without Redis, state is lost on crash and Round 1 after restart won't detect changes
REDIS_URL=redis://localhost:6379

# VFS Global credentials
# Account rotation: switches after each full sweep (18 centres = 3 sessions)
# to avoid "too many logins" error
VFS_EMAIL_ACCOUNT1=your-email-account1@example.com
VFS_EMAIL_ACCOUNT2=your-email-account2@example.com
VFS_EMAIL_ACCOUNT3=your-email-account3@example.com
VFS_EMAIL_ACCOUNT4=your-email-account4@example.com
VFS_PASSWORD=your-password

# Gmail API — for OTP reading (run npm run tools:gmail-token to get these)
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token

# Polling interval with jitter (randomized between min and max)
# IMPORTANT: Set conservatively to avoid rate limiting (HTTP 429)
# VFS Global may block your IP for 2 hours if you poll too aggressively
POLL_INTERVAL_MIN_MS=45000  # 45 seconds (minimum)
POLL_INTERVAL_MAX_MS=75000  # 75 seconds (maximum)

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# Telegram Notifications
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_supergroup_chat_id_here   # supergroup ID, format: -100xxxxxxxxxx
TELEGRAM_OWNER_CHAT_ID=your_personal_chat_id_here

# Telegram Topic Thread IDs (supergroup with topics/forum mode enabled)
# Get the thread ID from the topic URL: https://t.me/c/<group_id>/<thread_id>
TELEGRAM_TOPIC_FRANCE=2
# TELEGRAM_TOPIC_ITALY=7    # coming soon
# TELEGRAM_TOPIC_GERMANY=9  # coming soon

# Cooldown after account blocked by VFS 429001 Access Restricted (30 minutes)
ACCOUNT_BLOCK_COOLDOWN_MS=1800000

# Chrome executable path override (optional)
# If not set, the path is auto-detected based on the OS:
#   macOS   → /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
#   Windows → C:\Program Files\Google\Chrome\Application\chrome.exe
#   Linux   → /usr/bin/google-chrome
# Only set this if Chrome is installed in a non-standard location.
# CHROME_EXECUTABLE=/path/to/chrome
