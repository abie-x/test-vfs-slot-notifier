# VFS Global credentials
VFS_EMAIL=your-email@example.com
VFS_PASSWORD=your-password

# VFS appointment details (used in API payload)
VFS_COUNTRY_CODE=ind
VFS_MISSION_CODE=fra
VFS_VAC_CODE=AMD
VFS_VISA_CATEGORY=TOU

# VFS API tokens — copy these from browser DevTools Network tab
# (captured from a live CheckIsSlotAvailable request)
VFS_AUTHORIZE_TOKEN=
VFS_CLIENT_SOURCE=

# Polling interval in milliseconds (default: 30000 = 30 seconds)
POLL_INTERVAL_MS=30000

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info
